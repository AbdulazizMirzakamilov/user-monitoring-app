<Window x:Class="UserMonitoringApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Monitoring" Height="500" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#F5F6FA">
        <TabControl Margin="10" Background="White">

            <TabItem Header="Аномальная активность">
                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#EEF1F7" Padding="10" CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="5">
                                <TextBlock Text="Дата с" FontWeight="Bold"/>
                                <DatePicker x:Name="dateFrom"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5">
                                <TextBlock Text="Дата по" FontWeight="Bold"/>
                                <DatePicker x:Name="dateTo"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="5">
                                <TextBlock Text="Порог" FontWeight="Bold"/>
                                <TextBox x:Name="thresholdBox"/>
                            </StackPanel>

                            <Button Grid.Column="3"
                                    Content="Сформировать"
                                    Width="130"
                                    Height="35"
                                    Margin="10,20,0,0"
                                    Click="LoadReport_Click"/>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="2"
                              x:Name="dataGrid"
                              Margin="0,10,0,0"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"/>
                </Grid>
            </TabItem>

            <TabItem Header="IP анализ">
                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#EEF1F7" Padding="10" CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="5">
                                <TextBlock Text="Дата с" FontWeight="Bold"/>
                                <DatePicker x:Name="ipDateFrom"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5">
                                <TextBlock Text="Дата по" FontWeight="Bold"/>
                                <DatePicker x:Name="ipDateTo"/>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Content="Сформировать"
                                    Width="130"
                                    Height="35"
                                    Margin="10,20,0,0"
                                    Click="LoadIpReport_Click"/>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              x:Name="ipGrid"
                              Margin="0,10,0,0"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"/>
                </Grid>
            </TabItem>

            <TabItem Header="Непрерывная работа">
                <Grid Margin="10">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#EEF1F7" Padding="10" CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="5">
                                <TextBlock Text="Дата с" FontWeight="Bold"/>
                                <DatePicker x:Name="contDateFrom"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5">
                                <TextBlock Text="Дата по" FontWeight="Bold"/>
                                <DatePicker x:Name="contDateTo"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="5">
                                <TextBlock Text="Порог дней" FontWeight="Bold"/>
                                <TextBox x:Name="contThresholdBox"/>
                            </StackPanel>

                            <Button Grid.Column="3"
                        Content="Сформировать"
                        Width="130"
                        Height="35"
                        Margin="10,20,0,0"
                        Click="LoadContinuousReport_Click"/>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                  x:Name="contGrid"
                  Margin="0,10,0,0"
                  AutoGenerateColumns="True"
                  IsReadOnly="True"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>